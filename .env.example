# Redline · environment variables (Runbook §02)
# Copy to .env.local at repo root. .env.local is gitignored.

# --- runtime ---
NODE_ENV=development
PORT=8787
BASE_URL=http://localhost:8787

# --- ClickHouse Cloud (SQL endpoint) ---
CLICKHOUSE_URL=https://<id>.<region>.aws.clickhouse.cloud:8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# --- ClickHouse Cloud Management API (used only by scripts/reset-ch-password.ts) ---
CH_CLOUD_ORG_ID=
CH_CLOUD_SERVICE_ID=
CH_CLOUD_API_KEY_ID=
CH_CLOUD_API_KEY_SECRET=

# --- live providers (not used by issue #2) ---
NIMBLE_API_KEY=
GEMINI_API_KEY=
SENSO_API_KEY=
SLACK_WEBHOOK_URL=

# --- stripe (issue #3) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- scheduler / admin ---
SCAN_INTERVAL_SEC=60
ADMIN_TOKEN=demo_admin_2026
